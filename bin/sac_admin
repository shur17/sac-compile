  test -z $SAC_ADMIN_SSH_PORT || args="${args} --ssh-port $SAC_ADMIN_SSH_PORT"
  test -z $SAC_ADMIN_SSH_USER || args="${args} --ssh-user '$SAC_ADMIN_SSH_USER'"
  test -z $SAC_ADMIN_SSH_PASSWD || args="${args} --ssh-passwd '$SAC_ADMIN_SSH_PASSWD'"
  test -z $SAC_ADMIN_KEY_FILE || args="${args} --key-file $SAC_ADMIN_KEY_FILE"
  exec_cmd "$_java $DEFAULT_JVM_OPTS -jar $SAC_ADMIN_SDB_SSH_JAR_PATH $args"
}

