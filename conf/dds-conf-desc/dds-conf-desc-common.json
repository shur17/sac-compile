[
    {
        "name": "replication:oplogSizeMB",
        "supported": true,
        "type": "num",
        "role": [
            "config",
            "data"
        ],
        "desc": "The maximum size in megabytes for the oplog. The oplogSizeMB setting configures the uncompressed size of the oplog, not the size on disk.",
        "num_validator": {
            "left": {
                "value": 990,
                "include": true
            },
            "right": {
                "value": 1048576,
                "include": true
            }
        },
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "operationProfiling:mode",
        "supported": true,
        "type": "enum",
        "role": [
            "config",
            "data"
        ],
        "desc": "Specifies which operations should be profiled.",
        "enum_value": [
            "off",
            "slowOp",
            "all"
        ],
        "default_value": "off",
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "operationProfiling:slowOpThresholdMs",
        "supported": true,
        "type": "num",
        "role": [
            "router",
            "config",
            "data"
        ],
        "desc": "The slow operation time threshold, in milliseconds. Operations that run for longer than this threshold are considered slow.",
        "num_validator": {
            "left": {
                "value": 0,
                "include": true
            }
        },
        "default_value": 100,
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "systemLog:logAppend",
        "supported": true,
        "type": "boolean",
        "role": [
            "router",
            "config",
            "data"
        ],
        "desc": "When true, mongos or mongod appends new entries to the end of the existing log file when the instance restarts. Without this option, mongod or mongos backs up the existing log and create a new file.",
        "default_value": false,
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "systemLog:logRotate",
        "supported": true,
        "type": "enum",
        "role": [
            "router",
            "config",
            "data"
        ],
        "desc": "Determines the behavior for the logRotate command when rotating the server log and/or the audit log.",
        "enum_value": [
            "rename",
            "reopen"
        ],
        "default_value": "rename",
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "systemLog:destination",
        "supported": true,
        "type": "enum",
        "role": [
            "router",
            "config",
            "data"
        ],
        "desc": "The destination to which MongoDB sends all log output. Specify either 'file' or 'syslog'. If you specify file, you must also specify 'systemLog.path'.",
        "enum_value": [
            "file",
            "syslog"
        ],
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "systemLog:path",
        "supported": true,
        "type": "str",
        "role": [
            "router",
            "config",
            "data"
        ],
        "desc": "The path of the log file to which mongod or mongos should send all diagnostic logging information, rather than the standard output or the host's syslog. MongoDB creates the log file at the specified path.",
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": false
    },
    {
        "name": "storage:journal:enabled",
        "supported": true,
        "type": "boolean",
        "role": [
            "config",
            "data"
        ],
        "desc": "Enable or disable the durability journal to ensure data files remain valid and recoverable. This option applies only when you specify the storage.dbPath setting. mongod enables journaling by default.",
        "default_value": true,
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "storage:engine",
        "supported": true,
        "type": "enum",
        "role": [
            "config",
            "data"
        ],
        "desc": "The storage engine for the mongod database.",
        "enum_value": [
            "wiredTiger",
            "inMemory"
        ],
        "default_value": "wiredTiger",
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "storage:wiredTiger:engineConfig:cacheSizeGB",
        "supported": true,
        "type": "num",
        "role": [
            "config",
            "data"
