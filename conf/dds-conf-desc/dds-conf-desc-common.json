        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
    {
        "name": "storage:wiredTiger:engineConfig:directoryForIndexes",
        "supported": true,
        "type": "boolean",
        "role": [
            "config",
            "data"
        ],
        "desc": "When storage.wiredTiger.engineConfig.directoryForIndexes is true, mongod stores indexes and collections in separate subdirectories under the data (i.e. storage.dbPath) directory.",
        "default_value": false,
        "modifiedable": true,
        "effective_online": false,
        "support_online_modify": false,
        "support_batch_modify": true
    },
